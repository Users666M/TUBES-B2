<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Lagu - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #121212; color: white; padding: 40px; }
        .card { background-color: #181818; border: none; border-radius: 12px; padding: 30px; }
        .form-control { background-color: #333; border: 1px solid #444; color: white; margin-bottom: 15px; }
        .btn-success { background-color: #1DB954; border: none; font-weight: bold; color: black; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card shadow">
            <h2 class="fw-bold text-success mb-4">Edit Lagu</h2>
            <form action="/admin/songs/update/<%= song.id %>" method="POST">
                <label>Judul Lagu</label>
                <input type="text" name="title" class="form-control" value="<%= song.title %>" required>
                
                <label>Artis</label>
                <input type="text" name="artist" class="form-control" value="<%= song.artist %>" required>
                
                <label>Link MP3</label>
                <input type="text" name="url" class="form-control" value="<%= song.url %>">
                
                <label>Link Foto Cover</label>
                <input type="text" name="image_url" class="form-control" value="<%= song.image_url %>">
                
                <label>Lirik</label>
                <textarea name="lyrics" class="form-control" rows="5"><%= song.lyrics %></textarea>
                
                <div class="mt-3">
                    <button type="submit" class="btn btn-success px-5">Simpan Perubahan</button>
                    <a href="/admin/songs" class="btn btn-outline-light ms-2">Batal</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>