<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login -BEH Music</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: radial-gradient(circle at top left, #1db95422, #121212 70%); height: 100vh; display: flex; align-items: center; justify-content: center; color: white; font-family: sans-serif; }
        .card { background-color: #181818; border: none; border-radius: 12px; padding: 40px; width: 400px; box-shadow: 0 15px 35px rgba(0,0,0,0.5); }
        .form-control { background-color: #282828; border: 1px solid #3e3e3e; color: white; padding: 12px; border-radius: 8px; }
        .form-control:focus { background-color: #333; border-color: #1DB954; color: white; box-shadow: none; }
        .btn-spotify { background-color: #1DB954; color: black; font-weight: bold; border-radius: 50px; padding: 14px; border: none; width: 100%; transition: 0.3s; margin-top: 20px; }
        .btn-spotify:hover { background-color: #1ed760; transform: scale(1.02); }
        a { color: #1DB954; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <div class="card text-center">
        <h2 class="fw-bold mb-4" style="color: #b3b3b3;"><i class="bi bi-spotify"></i> Selamat Datang</h2>
        <form action="/login" method="POST">
            <div class="mb-3 text-start">
                <label class="small fw-bold text-secondary">Username</label>
                <input type="text" name="username" class="form-control" placeholder="Masukkan username" required>
            </div>
            <div class="mb-3 text-start">
                <label class="small fw-bold text-secondary">Password</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-spotify">MASUK</button>
        </form>
        <p class="mt-4 small text-secondary">Belum punya akun? <a href="/register">Daftar sekarang</a></p>
    </div>
</body>
</html>