<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BEH Music - Style</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        /* Tema Gelap Spotify */
        body { 
            background-color: #121212; 
            color: white; 
            font-family: 'Circular', 'Segoe UI', Roboto, sans-serif;
        }

        /* Navbar Samping/Atas */
        .navbar-spotify {
            background-color: #000000;
            padding: 15px 0;
        }

        .navbar-brand {
            color: #1DB954 !important;
            font-size: 1.5rem;
        }

        /* Kartu Lagu Style Spotify */
        .song-card { 
            background-color: #181818; 
            border: none; 
            border-radius: 8px; 
            padding: 16px;
            transition: background-color 0.3s ease;
            height: 100%;
        }
        
        .song-card:hover { 
            background-color: #282828; 
            cursor: pointer;
        }

        .song-title {
            color: white;
            font-size: 1.1rem;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .song-artist {
            color: #b3b3b3;
            font-size: 0.9rem;
        }

        /* Tombol Hijau Spotify */
        .btn-spotify {
            background-color: #1DB954;
            color: black;
            font-weight: bold;
            border-radius: 50px;
            border: none;
            padding: 8px 20px;
            transition: transform 0.2s;
        }

        .btn-spotify:hover {
            background-color: #1ed760;
            transform: scale(1.04);
            color: black;
        }

        /* Icon Hati */
        .fav-link {
            color: #b3b3b3;
            transition: 0.2s;
        }
        .fav-link:hover {
            color: #1DB954;
        }

        /* Modal Custom */
        .modal-content {
            background-color: #282828;
            color: white;
            border-radius: 12px;
        }
        .modal-header { border-bottom: 1px solid #3e3e3e; }
        .modal-footer { border-top: 1px solid #3e3e3e; }
        
        /* Audio Player Custom */
        audio {
            filter: invert(100%) hue-rotate(180deg) brightness(1.5);
            height: 35px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-spotify sticky-top mb-5 shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                <i ></i>BEH Music
            </a>
            <div class="d-flex align-items-center">
                <span class="text-white-50 me-3 small">Halo, <strong class="text-white"><%= nama %></strong></span>
                <a href="/logout" class="btn btn-outline-light btn-sm rounded-pill">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h2 class="fw-bold mb-4">Daftar Lagu Untukmu</h2>
        
        <div class="row">
            <% if (songs.length > 0) { %>
                <% songs.forEach(song => { %>
                <div class="col-6 col-md-4 col-lg-2 mb-4">
                    <div class="card song-card shadow" data-bs-toggle="modal" data-bs-target="#modalLirik<%= song.id %>">
                        <div class="bg-dark rounded mb-3 d-flex align-items-center justify-content-center shadow overflow-hidden" style="aspect-ratio: 1/1;">
                            <% if (song.image_url) { %>
                                <img src="<%= song.image_url %>" alt="Cover" style="width: 100%; height: 100%; object-fit: cover;">
                            <% } else { %>
                                <i class="bi bi-music-note-beamed fs-1 text-secondary"></i>
                            <% } %>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="overflow-hidden">
                                <h6 class="song-title mb-0"><%= song.title %></h6>
                                <p class="song-artist mb-2"><%= song.artist %></p>
                            </div>
                            <a href="/user/favorite/<%= song.id %>" class="fav-link ms-2" onclick="event.stopPropagation();">
                                <i class="bi bi-heart-fill"></i>
                            </a>
                        </div>
                        
                        <button class="btn btn-spotify btn-sm w-100 mt-2">Putar</button>
                    </div>
                </div>

                <div class="modal fade" id="modalLirik<%= song.id %>" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header border-0">
                                <h5 class="modal-title fw-bold"><%= song.title %></h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4">
                                <p class="text-white-50 mb-4">Artis: <span class="text-white"><%= song.artist %></span></p>
                                
                                <div class="bg-black p-3 rounded-3 mb-4 text-center">
                                    <p class="small text-white-50 mb-3"><i class="bi bi-play-circle me-1"></i> Player</p>
                                    <audio controls class="w-100">
                                        <source src="<%= song.url %>" type="audio/mpeg">
                                    </audio>
                                </div>

                                <h6 class="fw-bold text-success mb-3">Lirik</h6>
                                <div style="max-height: 200px; overflow-y: auto; white-space: pre-line;" class="text-white-50">
                                    <%= song.lyrics || "Lirik tidak tersedia." %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center mt-5">
                    <p class="text-white-50">Belum ada lagu. Admin sedang menyiapkan musik untukmu.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>