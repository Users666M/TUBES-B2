<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #121212; color: white; font-family: sans-serif; }
        .sidebar { width: 260px; height: 100vh; background-color: #000; position: fixed; padding: 25px; border-right: 1px solid #282828; }
        .main-content { margin-left: 260px; padding: 40px; background: linear-gradient(180deg, #1db95411 0%, #121212 400px); min-height: 100vh; }
        .nav-link { color: #b3b3b3 !important; border-radius: 8px; margin-bottom: 8px; font-weight: bold; padding: 12px; }
        .nav-link:hover { color: white !important; background: rgba(255,255,255,0.05); }
        .nav-link.active { background-color: #282828 !important; color: #1DB954 !important; }
        .stat-card { background-color: #181818; border: none; border-radius: 15px; padding: 30px; border-bottom: 4px solid #1DB954; }
        .logout-link { color: #b3b3b3; text-decoration: none; font-weight: bold; }
        .logout-link:hover { color: #ff4d4d; }
    </style>
</head>
<body>
    <div class="sidebar d-flex flex-column justify-content-between">
        <div>
            <h4 class="fw-bold mb-5 text-success"><i ></i> ADMIN PANEL</h4>
            <nav class="nav flex-column">
                <a class="nav-link active" href="/admin/dashboard"><i class="bi bi-grid-1x2-fill me-2"></i> Dashboard</a>
                <a class="nav-link" href="/admin/songs"><i class="bi bi-music-note-list me-2"></i> Kelola Lagu</a>
                <a class="nav-link" href="/admin/users"><i class="bi bi-people-fill me-2"></i> Daftar User</a>
            </nav>
        </div>
        <a href="/logout" class="logout-link mb-3 p-2"><i class="bi bi-box-arrow-right me-2"></i> Keluar Sistem</a>
    </div>

    <div class="main-content">
        <h2 class="fw-bold mb-4">Statistik Aplikasi</h2>
        <div class="row">
            <div class="col-md-4">
                <div class="card stat-card shadow">
                    <div class="d-flex align-items-center">
                        <div class="bg-dark text-success p-3 rounded-3 me-4"><i class="bi bi-person-check fs-1"></i></div>
                        <div>
                            <p class="text-secondary mb-0 small fw-bold">TOTAL PENGGUNA</p>
                            <h1 class="fw-bold mb-0 text-white"><%= statistik %></h1>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>