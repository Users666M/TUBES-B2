<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Daftar User - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #121212; color: white; }
        .sidebar { width: 260px; height: 100vh; background-color: #000; position: fixed; padding: 25px; border-right: 1px solid #282828; }
        .main-content { margin-left: 260px; padding: 40px; min-height: 100vh; }
        .nav-link { color: #b3b3b3 !important; border-radius: 8px; margin-bottom: 8px; font-weight: bold; padding: 12px; }
        .nav-link.active { background-color: #282828 !important; color: #1DB954 !important; }
        .card { background-color: #181818; border: none; border-radius: 12px; }
        .table { color: #b3b3b3; }
        .table thead th { border-bottom: 1px solid #3e3e3e; color: white; }
        .badge-fav { background-color: #1DB954; color: black; font-weight: bold; border-radius: 50px; padding: 5px 15px; }
    </style>
</head>
<body>
    <div class="sidebar d-flex flex-column justify-content-between">
        <div>
            <h4 class="fw-bold mb-5 text-success"><i></i> ADMIN PANEL</h4>
            <nav class="nav flex-column">
                <a class="nav-link" href="/admin/dashboard"><i class="bi bi-grid-1x2-fill me-2"></i> Dashboard</a>
                <a class="nav-link" href="/admin/songs"><i class="bi bi-music-note-list me-2"></i> Kelola Lagu</a>
                <a class="nav-link active" href="/admin/users"><i class="bi bi-people-fill me-2"></i> Daftar User</a>
            </nav>
        </div>
        <a href="/logout" class="logout-link text-secondary text-decoration-none mb-3 p-2"><i class="bi bi-box-arrow-right me-2"></i> Keluar</a>
    </div>

    <div class="main-content">
        <h2 class="fw-bold mb-4">Manajemen Pengguna</h2>
        <div class="card p-3 shadow">
            <table class="table table-hover align-middle">
                <thead><tr><th class="text-black">Username</th><th class="text-black">Password (Hash)</th><th class="text-black">Lagu Favorit</th></tr></thead>
                <tbody>
                    <% users.forEach(user => { %>
                    <tr>
                        <td class="text-black fw-bold"><%= user.username %></td>
                        <td class="small"><code class="text-muted"><%= user.password.substring(0, 30) %>...</code></td>
                        <td><span class="badge badge-fav"><%= user.koleksi_favorit || "Kosong" %></span></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>