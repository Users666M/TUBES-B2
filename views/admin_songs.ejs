<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Kelola Lagu - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #121212; color: white; }
        .sidebar { width: 260px; height: 100vh; background-color: #000; position: fixed; padding: 25px; border-right: 1px solid #282828; }
        .main-content { margin-left: 260px; padding: 40px; min-height: 100vh; }
        .nav-link { color: #b3b3b3 !important; border-radius: 8px; margin-bottom: 8px; font-weight: bold; padding: 12px; }
        .nav-link.active { background-color: #282828 !important; color: #1DB954 !important; }
        .card { background-color: #181818; border: none; border-radius: 12px; }
        .form-control { background-color: #beb9b9; border: 1px solid #3e3e3e; color: white; }
        .form-control:focus { background-color: #222; border-color: #1DB954; color: white; box-shadow: none; }
        .table { color: #b3b3b3; }
        .table thead th { border-bottom: 1px solid #3e3e3e; color: white; }
        .btn-success { background-color: #1DB954; border: none; color: black; font-weight: bold; }
    </style>
</head>
<body>
    <div class="sidebar d-flex flex-column justify-content-between">
        <div>
            <h4 class="fw-bold mb-5 text-success"><i ></i> ADMIN PANEL</h4>
            <nav class="nav flex-column">
                <a class="nav-link" href="/admin/dashboard"><i class="bi bi-grid-1x2-fill me-2"></i> Dashboard</a>
                <a class="nav-link active" href="/admin/songs"><i class="bi bi-music-note-list me-2"></i> Kelola Lagu</a>
                <a class="nav-link" href="/admin/users"><i class="bi bi-people-fill me-2"></i> Daftar User</a>
            </nav>
        </div>
        <a href="/logout" class="logout-link text-secondary text-decoration-none mb-3 p-2"><i class="bi bi-box-arrow-right me-2"></i> Keluar</a>
    </div>

    <div class="main-content">
        <h2 class="fw-bold mb-4">Kelola Koleksi Lagu</h2>
        <div class="card p-4 mb-4">
            <h5 class="fw-bold text-success mb-3">Tambah Lagu Baru</h5>
            <form action="/admin/songs/add" method="POST" class="row g-3">
                <div class="col-md-6"><input type="text" name="title" class="form-control" placeholder="Judul Lagu" required></div>
                <div class="col-md-6"><input type="text" name="artist" class="form-control" placeholder="Artis" required></div>
                <div class="col-md-12"><input type="text" name="url" class="form-control" placeholder="Link MP3 (.mp3)"></div>
                <div class="mb-3"><input type="text" class="form-control" id="image_url" name="image_url" placeholder="Paste link foto (https://...)"></div>
                <div class="col-md-12"><textarea name="lyrics" class="form-control" rows="3" placeholder="Lirik Lagu"></textarea></div>
                <div class="col-12"><button type="submit" class="btn btn-success px-4">Simpan Lagu</button></div>
            </form>
        </div>
        <div class="card p-3 shadow">
            <table class="table table-hover align-middle">
                <thead><tr><th class="text-black">Judul</th><th class="text-black">Artis</th><th class="text-center">Aksi</th></tr></thead>
                <tbody>
                    <% songs.forEach(song => { %>
                    <tr>
                        <td class="text-black fw-bold"><%= song.title %></td>
                        <td class="text-black"><%= song.artist %></td>
                        <td class="text-center"><a href="/admin/songs/delete/<%= song.id %>" class="btn btn-outline-danger btn-sm rounded-pill" onclick="return confirm('Hapus?')"><i class="bi bi-trash"></i></a></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>